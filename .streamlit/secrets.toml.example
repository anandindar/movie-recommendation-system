# STREAMLIT CLOUD CONFIGURATION
# Copy this to .streamlit/secrets.toml for local development
# For Streamlit Cloud: Add these secrets via the app settings dashboard

MYSQL_HOST = "your-mysql-host.com"
MYSQL_USER = "your_username"
MYSQL_PASSWORD = "your_password"
MYSQL_DATABASE = "movie_recommendation_db"

# ════════════════════════════════════════════════════════════════════════════
# SETUP FOR STREAMLIT CLOUD:
# ════════════════════════════════════════════════════════════════════════════
# 
# 1. Go to: https://share.streamlit.io/apps
# 2. Find your app and click "Manage app" (bottom right)
# 3. Go to "Secrets" section
# 4. Add the values above
# 5. Replace localhost with your cloud MySQL host
# 
# Note: For Streamlit Cloud to work, you need either:
#   - A cloud-hosted MySQL database (e.g., AWS RDS, Azure Database, etc.)
#   - OR a remote MySQL server accessible from the internet
# 
# localhost won't work on Streamlit Cloud since it's a public deployment
